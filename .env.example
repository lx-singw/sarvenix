# RTS
RTS_API_KEY=
RTS_INDEX_MUTED_CHANNELS=false

# Serve Mode
SERVE_MODE_RATE_LIMIT_PER_CHANNEL_PER_DAY=5
SERVE_MODE_ENABLED=true
ADVERSARIAL_VERIFICATION_ENABLED=true

# Competition sandbox (never enable fixture demo mode in production)
SARVENIX_SANDBOX_MODE=false
SANDBOX_SLACK_WORKSPACE_ID=
SANDBOX_GITHUB_REPOSITORY=
SANDBOX_JIRA_PROJECT_KEY=

# Feature controls
FEATURE_DURABLE_THREADS=true
FEATURE_IMPACT_RADIUS=true
FEATURE_COUNTERFACTUAL_PREVIEW=true
FEATURE_PER_USER_OAUTH=false

# General
NODE_ENV=development
LOG_LEVEL=info
DEMO_MODE=false
